import pygame as pg
import math
import numpy as np
import random
import time

WIDTH = 1600
HEIGHT = 900
WHITE = (255, 255, 255)
RED = (255, 0, 0)
BLACK = (0, 0, 0)
GREEN = (0, 255, 0)
BLUE = (0, 0, 255)

FPS = 60

# Neural Network parameters
INPUT_SIZE = 8  # 8 sensor values
HIDDEN_SIZE = 10  # Neurons in hidden layer
OUTPUT_SIZE = 2  # [Acceleration, Steering]

pg.init()
screen = pg.display.set_mode((WIDTH, HEIGHT))
pg.display.set_caption("Learning Car Game")

class NeuralNetwork:
    def __init__(self, weights=None):
        # Initialize weights randomly if not provided
        if weights is None:
            # Create weights for input -> hidden, hidden -> output
            self.weights = np.random.uniform(-1, 1, INPUT_SIZE * HIDDEN_SIZE + HIDDEN_SIZE * OUTPUT_SIZE)
        else:
            self.weights = weights
            
    def forward(self, inputs):
        # Reshape weights
        w1_size = INPUT_SIZE * HIDDEN_SIZE
        w1 = self.weights[:w1_size].reshape(INPUT_SIZE, HIDDEN_SIZE)
        w2 = self.weights[w1_size:].reshape(HIDDEN_SIZE, OUTPUT_SIZE)
        
        # Forward pass
        hidden = np.tanh(np.dot(inputs, w1))  # Tanh activation
        output = np.tanh(np.dot(hidden, w2))  # Tanh activation
        
        return output
    
    def get_weights(self):
        return self.weights

class Car:
    def __init__(self, weights=None):
        self.angle = 180
        self.position = pg.math.Vector2(WIDTH // 2 + 20, 89)
        self.velocity = pg.math.Vector2(0, 0)
        self.acceleration = 0
        self.thrust = 0.2        # Acceleration amount per frame
        self.friction = 0.955    # Friction multiplier per frame (closer to 1 = less friction)
        self.alive = True
        self.checkpoint_number = 0
        self.distance_traveled = 0
        self.last_position = self.position.copy()
        self.time_alive = 0
        self.brain = NeuralNetwork(weights)
        self.fitness = 0
        
        # For visualization
        self.color = (
            random.randint(100, 255),
            random.randint(100, 255),
            random.randint(100, 255)
        )

    def calculate_fitness(self):
        checkpoint_bonus = self.checkpoint_number * 1000
        time_penalty = max(0, 60 - self.time_alive) * 10  # Reward for surviving longer (up to 60 seconds)
        self.fitness = checkpoint_bonus + self.distance_traveled + time_penalty
        return self.fitness

    def start_accelerating(self):
        self.acceleration = self.thrust

    def start_braking(self):
        self.acceleration = -self.thrust

    def stop_acceleration(self):
        self.acceleration = 0

    def think(self, sensor_values):
        # Normalize sensor values (0-200 range to 0-1)
        normalized_inputs = np.array(sensor_values) / 200.0
        
        # Get outputs from neural network
        outputs = self.brain.forward(normalized_inputs)
        
        # Apply outputs to car controls
        # Output[0] controls acceleration (-1 to 1)
        if outputs[0] > 0.5:
            self.start_accelerating()
        elif outputs[0] < -0.5:
            self.start_braking()
        else:
            self.stop_acceleration()
            
        # Output[1] controls steering (-1 to 1)
        self.angle += outputs[1] * 3  # Scale steering

    def update(self):
        if not self.alive:
            self.acceleration = 0
            self.velocity *= 0.10
            if self.velocity.length() < 0.05:
                self.velocity = pg.math.Vector2(0, 0)
            self.position += self.velocity
            return
            
        # Track time alive
        self.time_alive += 1/FPS  # Assuming 60 FPS
        
        # Store previous position for distance calculation
        self.last_position = self.position.copy()
        
        rad = math.radians(self.angle)
        direction = pg.math.Vector2(math.cos(rad), math.sin(rad))
        self.velocity += direction * self.acceleration
        self.velocity *= self.friction

        # Stop completely if velocity is very small and no acceleration is applied
        if self.velocity.length() <= 0.1 and self.acceleration == 0:
            self.velocity = pg.math.Vector2(0, 0)

        self.position += self.velocity
        
        # Calculate distance traveled
        self.distance_traveled += self.last_position.distance_to(self.position)

        # Keep car inside the screen bounds (optional)
        self.position.x = max(0, min(WIDTH, self.position.x))
        self.position.y = max(0, min(HEIGHT, self.position.y))

    def sense(self, track_mask, screen, draw=False):
        sensor_angles = [-120, -60, -30, 0, 30, 60, 120, 180]
        sensor_distances = []

        for offset_angle in sensor_angles:
            angle = math.radians(self.angle + offset_angle)
            direction = pg.math.Vector2(math.cos(angle), math.sin(angle))
            sensor_length = 0
            point = self.position.copy()

            # Raycast until wall or max range
            while (0 <= point.x < WIDTH and 0 <= point.y < HEIGHT and 
                   track_mask.get_at((int(point.x), int(point.y))) == 0 and 
                   sensor_length < 200):
                point += direction
                sensor_length += 1

            # Draw the ray if requested
            if draw:
                end_point = (int(self.position.x + direction.x * sensor_length),
                             int(self.position.y + direction.y * sensor_length))
                pg.draw.line(screen, (0, 255, 0), self.position, end_point, 1)  # Green sensor line

            sensor_distances.append(sensor_length)

        return sensor_distances

    def score(self, time):
        self.calculate_fitness()
        print(f"Car reached checkpoint {self.checkpoint_number} in {time:.2f} seconds")
        print(f"Distance traveled: {self.distance_traveled:.2f}")
        print(f"Fitness score: {self.fitness:.2f}")

    def get_mask_and_rect(self):
        car_width, car_height = 40, 20
        car_surf = pg.Surface((car_width, car_height), pg.SRCALPHA)
        
        # Use custom color for the car if it's alive, darker version if dead
        if self.alive:
            car_color = self.color
        else:
            car_color = (self.color[0]//2, self.color[1]//2, self.color[2]//2)
            
        car_surf.fill(car_color)
        
        # Add direction arrow
        arrow_points = [
            (car_width * 0.7, car_height // 2),
            (car_width * 0.4, car_height * 0.3),
            (car_width * 0.4, car_height * 0.7)
        ]
        pg.draw.polygon(car_surf, BLACK, arrow_points)

        rotated_surf = pg.transform.rotate(car_surf, -self.angle)
        rotated_rect = rotated_surf.get_rect(center=self.position)

        car_mask = pg.mask.from_surface(rotated_surf)
        return rotated_surf, car_mask, rotated_rect

    def draw(self, surface):
        rotated_surf, _, rotated_rect = self.get_mask_and_rect()
        surface.blit(rotated_surf, rotated_rect)


def check_checkpoint_crossing(car):
    if car.checkpoint_number >= len(CHECKPOINTS):
        return False

    _, _, car_rect = car.get_mask_and_rect()

    p1, p2 = CHECKPOINTS[car.checkpoint_number]

    clipped_line = car_rect.clipline(p1, p2)
    if clipped_line:
        car.checkpoint_number += 1
        if car.checkpoint_number >= len(CHECKPOINTS):
            car.checkpoint_number = 0
        return True  # Checkpoint was crossed
    return False


# Genetic Algorithm parameters
POPULATION_SIZE = 50
GENOME_LENGTH = INPUT_SIZE * HIDDEN_SIZE + HIDDEN_SIZE * OUTPUT_SIZE
SURVIVORS = 5
MUTATION_RATE = 0.1
CHECKPOINT_TIMEOUT = 3.0  # Seconds since last checkpoint before ending generation

def breed(parent1, parent2):
    # Single point crossover
    crossover_point = random.randint(1, GENOME_LENGTH - 1)
    child_genome = np.concatenate([parent1.brain.get_weights()[:crossover_point], 
                                  parent2.brain.get_weights()[crossover_point:]])
    
    # Mutation
    for i in range(len(child_genome)):
        if random.random() < MUTATION_RATE:
            child_genome[i] += random.uniform(-0.2, 0.2)
            child_genome[i] = max(min(child_genome[i], 1), -1)  # keep weights in [-1,1]

    return Car(child_genome)

def evolve_population(population):
    # Calculate fitness for all cars
    for car in population:
        car.calculate_fitness()
    
    # Sort cars by fitness
    population.sort(key=lambda c: c.fitness, reverse=True)
    
    # Print stats
    best_car = population[0]
    print(f"Best fitness: {best_car.fitness:.2f}, Checkpoints: {best_car.checkpoint_number}, Distance: {best_car.distance_traveled:.2f}")

    # Keep top survivors
    survivors = population[:SURVIVORS]

    # Breed new population
    new_population = []
    
    # Add elite (unchanged top performers)
    elite_count = 5
    for i in range(elite_count):
        new_car = Car(survivors[i].brain.get_weights())
        new_population.append(new_car)
    
    # Fill the rest through breeding
    while len(new_population) < POPULATION_SIZE:
        # Tournament selection
        parent1 = random.choice(survivors[:5])  # Bias toward better performers
        parent2 = random.choice(survivors)
        child = breed(parent1, parent2)
        new_population.append(child)
        
    return new_population

def run_simulation(population, track, checkpoints):
    """Run a single generation simulation"""
    clock = pg.time.Clock()
    font = pg.font.SysFont(None, 36)
    
    # Track simulation time and time since last checkpoint
    start_time = time.time()
    last_checkpoint_time = start_time  # Time when any car last crossed a checkpoint
    running = True
    
    # For visualization
    show_sensors = True
    show_all_cars = True
    best_car_index = 0
    
    while running:
        elapsed_time = time.time() - start_time
        time_since_checkpoint = time.time() - last_checkpoint_time
        
        # Check if we should end this generation
        cars_alive = sum(1 for car in population if car.alive)
        
        # End if timeout reached or no cars alive
        if time_since_checkpoint > CHECKPOINT_TIMEOUT or cars_alive == 0:
            running = False
            break
        
        # Process events
        for event in pg.event.get():
            if event.type == pg.QUIT:
                pg.quit()
                exit()
            if event.type == pg.KEYDOWN:
                if event.key == pg.K_s:
                    show_sensors = not show_sensors
                if event.key == pg.K_a:
                    show_all_cars = not show_all_cars
                    
        # Update all cars
        checkpoint_crossed_this_frame = False
        for car in population:
            if car.alive:
                # Get sensor data
                sensor_values = car.sense(track.mask, screen, draw=False)
                
                # Let the car make a decision
                car.think(sensor_values)
                
                # Update car position
                car.update()
                
                # Check checkpoint crossing
                if check_checkpoint_crossing(car):
                    checkpoint_crossed_this_frame = True
                
                # Check collision
                rotated_surf, car_mask, car_rect = car.get_mask_and_rect()
                offset = (car_rect.left, car_rect.top)
                if track.mask.overlap(car_mask, offset):
                    car.alive = False
        
        # Update last checkpoint time if any car crossed a checkpoint
        if checkpoint_crossed_this_frame:
            last_checkpoint_time = time.time()
        
        # Find the best performing car for display
        alive_cars = [c for c in population if c.alive]
        if alive_cars:
            # Sort by checkpoints reached then by distance
            alive_cars.sort(key=lambda c: (c.checkpoint_number, c.distance_traveled), reverse=True)
            if alive_cars:
                best_car_index = population.index(alive_cars[0])
        
        # Drawing
        screen.fill(WHITE)
        screen.blit(track.surface, (0, 0))
        
        # Draw checkpoints
        checkpoints.surface.fill((0, 0, 0, 0))  # Clear
        
        # Draw active checkpoint for best car
        best_car = population[best_car_index]
        if best_car.checkpoint_number < len(CHECKPOINTS):
            checkpoints.draw_checkpoints(active_only=True, active_index=best_car.checkpoint_number)
        
        screen.blit(checkpoints.surface, (0, 0))
        
        # Draw cars based on settings
        if show_all_cars:
            for i, car in enumerate(population):
                car.draw(screen)
                # Draw sensors only for best car
                if i == best_car_index and car.alive and show_sensors:
                    car.sense(track.mask, screen, draw=True)
        else:
            # Just draw the best car
            best_car = population[best_car_index]
            best_car.draw(screen)
            if best_car.alive and show_sensors:
                best_car.sense(track.mask, screen, draw=True)
        
        # Draw stats
        alive_count = sum(1 for car in population if car.alive)
        gen_text = font.render(f"Generation: {generation+1}", True, BLACK)
        alive_text = font.render(f"Cars Alive: {alive_count}/{POPULATION_SIZE}", True, BLACK)
        time_text = font.render(f"Time: {elapsed_time:.1f}s", True, BLACK)
        timeout_text = font.render(f"Timeout in: {max(0, CHECKPOINT_TIMEOUT - time_since_checkpoint):.1f}s", True, RED)
        checkpoint_text = font.render(f"Best Checkpoint: {max(car.checkpoint_number for car in population)}/{len(CHECKPOINTS)}", True, BLACK)
        
        screen.blit(gen_text, (WIDTH//2 + 50, HEIGHT//2 - 200))
        screen.blit(alive_text, (WIDTH//2 + 50, HEIGHT//2 - 160))
        screen.blit(time_text, (WIDTH//2 + 50, HEIGHT//2 - 120))
        screen.blit(timeout_text, (WIDTH//2 + 50, HEIGHT//2 - 80))
        screen.blit(checkpoint_text, (WIDTH//2 + 50, HEIGHT//2 - 40))
        
        # Update display
        pg.display.flip()
        clock.tick(FPS)
    
    # Return final population for evolution
    return population

def main():
    # Initialize pygame and game objects
    track = Track()
    track.draw()
    checkpoints = CheckpointLayer()
    
    # Create initial population
    population = [Car() for _ in range(POPULATION_SIZE)]
    
    # Run for multiple generations
    global generation
    generation = 0
    num_generations = 1000
    
    # Main loop
    running = True
    while running and generation < num_generations:
        print(f"\n--- Generation {generation+1} ---")
        
        # Run the simulation for this generation
        final_population = run_simulation(population, track, checkpoints)
        
        # Evolve population for next generation
        population = evolve_population(final_population)
        
        generation += 1
        
        # Check if user wants to quit
        for event in pg.event.get():
            if event.type == pg.QUIT:
                running = False

    pg.quit()

if __name__ == "__main__":
    main()

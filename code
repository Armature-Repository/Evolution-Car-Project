        self.surface = pg.Surface((WIDTH, HEIGHT)).convert_alpha()
        self.surface.fill((0, 0, 0, 0))

    def draw_checkpoints(self, active_only=False, active_index=0):
        checkpoints = CHECKPOINTS

        for i, (p1, p2) in enumerate(checkpoints):

            if active_only and i != active_index:
